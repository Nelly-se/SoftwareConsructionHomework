<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="课堂作业 - 计算器" Height="350" Width="250">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="txtDisplay" Grid.Row="0" Height="50" FontSize="24" TextAlignment="Right" VerticalContentAlignment="Center" Margin="0,0,0,10" IsReadOnly="True"/>

        <UniformGrid Grid.Row="1" Columns="4" Rows="4">
            <Button Content="7" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="8" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="9" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="/" Click="Operator_Click" FontSize="20" Margin="2"/>

            <Button Content="4" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="5" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="6" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="*" Click="Operator_Click" FontSize="20" Margin="2"/>

            <Button Content="1" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="2" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="3" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="-" Click="Operator_Click" FontSize="20" Margin="2"/>

            <Button Content="C" Click="Clear_Click" FontSize="20" Margin="2"/>
            <Button Content="0" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button Content="=" Click="Equal_Click" FontSize="20" Margin="2"/>
            <Button Content="+" Click="Operator_Click" FontSize="20" Margin="2"/>
        </UniformGrid>
    </Grid>
</Window>